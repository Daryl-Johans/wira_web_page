---
// Layout.astro — Plantilla base. Sin style scoped. Usa solo clases globales.
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Wira Systems | El Sistema POS Multirubro para tu Negocio',
  description = 'El sistema POS ideal para restaurantes, hoteles, billares y ferreterías. Administra ventas, mesas, habitaciones, tiempos de juego, inventario y cajas sin comisiones de venta.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = savedTheme || (prefersDark ? 'dark' : 'light');
        if (theme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <!-- Fuerza que el navegador no use ningún SW previo (de Flutter) -->
    <meta http-equiv="Clear-Site-Data" content="cache, cookies, storage" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="theme-color" content="#0a0f1e" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f8fafc" media="(prefers-color-scheme: light)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;0,700;0,800;1,600;1,800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <!-- Desregistra Service Worker de Flutter si existe -->
    <script>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations().then((registrations) => {
          for (const reg of registrations) {
            reg.unregister();
          }
        });
      }
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Saltar al contenido</a>
    <header class="site-header">
      <div class="wira-container header-inner">
        <a class="brand" href={import.meta.env.BASE_URL} aria-label="Wira — Inicio">
          <img
            src={`${import.meta.env.BASE_URL}logo-wira-final.svg`}
            alt="Logo Wira"
            class="brand-logo-img"
            width="32"
            height="32"
          />
          <span class="brand-logo">wira</span>
        </a>
        <nav class="nav-desktop" aria-label="Navegación principal">
          <a href="#caracteristicas" class="nav-link">Características</a>
          <a href="#hardware" class="nav-link">Hardware</a>
          <a href="#planes" class="nav-link">Planes</a>
          <a href="#descarga" class="nav-link">Descarga</a>
          <a href="#faq" class="nav-link">FAQ</a>
          <a href="#contacto" class="nav-link">Contáctanos</a>
        </nav>
        <div class="header-ctas">
          <a href="#planes" class="nav-cta-ghost">Ver planes</a>
          <a href="#contacto" class="nav-cta-primary" id="header-cta-probar">Probar gratis</a>
        </div>
        <button
          id="theme-toggle"
          class="theme-toggle"
          aria-label="Activar tema claro"
          aria-pressed="false"
          type="button"
        >
          <!-- Icono de Sol (visible en modo oscuro por defecto) -->
          <svg
            class="sun-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="M4.93 4.93l1.41 1.41"></path>
            <path d="M17.66 17.66l1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="M6.34 17.66l-1.41 1.41"></path>
            <path d="M19.07 4.93l-1.41 1.41"></path>
          </svg>
          <!-- Icono de Luna (visible en modo claro) -->
          <svg
            class="moon-icon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
        </button>
        <button
          class="hamburger"
          id="hamburger-btn"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Abrir menú"
          type="button"
        >
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
      </div>
      <nav class="nav-mobile" id="mobile-menu" aria-label="Menú móvil" aria-hidden="true" inert>
        <div class="nav-mobile-inner">
          <a href="#caracteristicas" class="mobile-link">Características</a>
          <a href="#hardware" class="mobile-link">Hardware</a>
          <a href="#planes" class="mobile-link">Planes</a>
          <a href="#descarga" class="mobile-link">Descarga</a>
          <a href="#faq" class="mobile-link">FAQ</a>
          <a href="#contacto" class="mobile-link">Contáctanos</a>
          <a href="#contacto" class="mobile-cta" id="mobile-cta-probar">Probar gratis</a>
        </div>
      </nav>
    </header>


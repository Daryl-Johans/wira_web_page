<style>
  .plan-price,
  .plan-period {
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .plan-price.is-switching,
  .plan-period.is-switching {
    opacity: 0;
    transform: translateY(-6px);
  }

  /* Subtexto de equivalencia mensual */
  .plan-price-equiv {
    font-size: 0.78rem;
    color: var(--color-text-muted, #888);
    margin: 0.15rem 0 0;
    min-height: 1.2em;
    transition: opacity 0.2s ease;
  }
  .plan-price-equiv:empty {
    display: none;
  }

  /* Badge "2 meses gratis" */
  .plan-annual-badge {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 0.3rem 0.9rem;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 999px;
    letter-spacing: 0.02em;
    opacity: 0;
    transform: scale(0.85);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
    pointer-events: none;
  }
  .plan-annual-badge.is-visible {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }
</style>

<script>
  const tabMensual = document.getElementById('tab-mensual') as HTMLButtonElement | null;
  const tabAnual = document.getElementById('tab-anual') as HTMLButtonElement | null;

  const prices = document.querySelectorAll<HTMLElement>('.plan-price[data-monthly]');
  const periods = document.querySelectorAll<HTMLElement>('.plan-period[data-monthly]');
  const equivEls = document.querySelectorAll<HTMLElement>('.plan-price-equiv');
  const badges = document.querySelectorAll<HTMLElement>('.plan-annual-badge');
  const planCtas = document.querySelectorAll<HTMLAnchorElement>('.plan-cta[data-plan]');

  // Equivalentes mensuales reales (precio anual / 12)
  const monthlyEquiv = ['Bs 103,33', 'Bs 207,50', 'Bs 415,83'];

  const WHATSAPP_NUMBER = '59178960077';

  function buildWhatsAppHref(planName: string, price: string, period: string): string {
    const message = `Hola, quiero contratar el Plan ${planName} (${price}${period}).`;
    return `https://wa.me/${WHATSAPP_NUMBER}?text=${encodeURIComponent(message)}`;
  }

  function updatePlanCtas(isAnnual: boolean) {
    planCtas.forEach((cta) => {
      const card = cta.closest('.plan-card');
      if (!card) return;
      const priceEl = card.querySelector<HTMLElement>('.plan-price');
      if (!priceEl) return;
      const planName = cta.dataset.plan ?? '';
      const price = isAnnual ? (priceEl.dataset.annual ?? '') : (priceEl.dataset.monthly ?? '');
      const period = isAnnual ? '/año' : '/mes';
      cta.href = buildWhatsAppHref(planName, price, period);
    });
  }

  function switchPrices(mode: 'monthly' | 'annual') {
    const isAnnual = mode === 'annual';

    // Actualizar enlaces de WhatsApp con el ciclo y precio correspondientes
    updatePlanCtas(isAnnual);

    // Efecto de salida en precio y período
    prices.forEach((el) => el.classList.add('is-switching'));
    periods.forEach((el) => el.classList.add('is-switching'));

    setTimeout(() => {
      // Actualizar precios
      prices.forEach((el) => {
        el.textContent = isAnnual ? (el.dataset.annual ?? '') : (el.dataset.monthly ?? '');
        el.classList.remove('is-switching');
      });

      // Actualizar período (/mes o /año)
      periods.forEach((el) => {
        el.textContent = isAnnual ? (el.dataset.annual ?? '/año') : (el.dataset.monthly ?? '/mes');
        el.classList.remove('is-switching');
      });

      // Mostrar u ocultar subtexto de equivalencia
      equivEls.forEach((el, i) => {
        el.textContent = isAnnual ? `Equivale a ~ ${monthlyEquiv[i]} / mes` : '';
      });

      // Mostrar u ocultar badge "2 meses gratis"
      badges.forEach((el) => {
        el.classList.toggle('is-visible', isAnnual);
      });
    }, 200);

    // Actualizar estado de tabs
    tabMensual?.classList.toggle('billing-tab-active', !isAnnual);
    tabAnual?.classList.toggle('billing-tab-active', isAnnual);
    tabMensual?.setAttribute('aria-pressed', String(!isAnnual));
    tabAnual?.setAttribute('aria-pressed', String(isAnnual));
  }

  // Inicializar enlaces de WhatsApp con el ciclo mensual por defecto
  updatePlanCtas(false);

  tabMensual?.addEventListener('click', () => switchPrices('monthly'));
  tabAnual?.addEventListener('click', () => switchPrices('annual'));
</script>

---
// Pricing.astro — usa exclusivamente clases globales de global.css
---

<section class="wira-pricing" id="planes" aria-labelledby="pricing-title">
  <div class="wira-container">
    <div class="pricing-header reveal">
      <span class="wira-section-badge wira-section-badge-green">Precios</span>
      <h2 id="pricing-title" class="wira-section-title">Planes a tu medida</h2>
      <p class="wira-section-sub">
        Sin contratos. Apps instalables para Windows y Android (con web para ciertas cosas). Cancela
        cuando quieras.
      </p>
      <div class="billing-tabs" role="group" aria-label="Frecuencia de pago">
        <button
          class="billing-tab billing-tab-active"
          type="button"
          id="tab-mensual"
          aria-pressed="true">Mensual</button
        >
        <button class="billing-tab" type="button" id="tab-anual" aria-pressed="false"
          >Anual <span class="billing-save">−20%</span></button
        >
      </div>
    </div>

    <div class="plans-row">
      <!-- Básico -->
      <div class="plan-card reveal" id="plan-basico">
        <div class="plan-head">
          <h3 class="plan-name plan-name-blue">Básico</h3>
          <div class="plan-price-row">
            <span class="plan-price" data-monthly="Bs 124" data-annual="Bs 1.240">Bs 124</span>
            <span class="plan-period" data-monthly="/mes" data-annual="/año">/mes</span>
          </div>
          <p class="plan-price-equiv" aria-live="polite"></p>
          <span class="plan-annual-badge" aria-hidden="true">🎁 2 meses gratis</span>
        </div>
        <ul class="plan-features" aria-label="Beneficios plan Básico">
          <li class="plan-feature">
            <svg class="check-svg check-blue" viewBox="0 0 20 20" fill="currentColor"
              ><path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path></svg
            >1 Sucursal
          </li>
          <li class="plan-feature">
            <svg class="check-svg check-blue" viewBox="0 0 20 20" fill="currentColor"
              ><path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path></svg
            >1 Usuario
          </li>
          <li class="plan-feature">
            <svg class="check-svg check-blue" viewBox="0 0 20 20" fill="currentColor"
              ><path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path></svg
            >Ventas en tiempo real
          </li>
          <li class="plan-feature">
            <svg class="check-svg check-blue" viewBox="0 0 20 20" fill="currentColor"
              ><path
                fill-rule="evenodd"
                d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"
                clip-rule="evenodd"></path></svg
            >Soporte por WhatsApp
          </li>
        </ul>
        <a
          class="plan-cta plan-cta-blue"
          href="https://wa.me/59178960077?text=Hola%2C%20quiero%20contratar%20el%20Plan%20B%C3%A1sico"
          target="_blank"
          rel="noopener noreferrer"
          id="cta-plan-basico"
          data-plan="Básico">Elegir Plan Básico</a
        >
      </div>

      <!-- Estándar Popular -->
      <div

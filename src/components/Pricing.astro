                clip-rule="evenodd"></path></svg
            >Soporte prioritario
          </li>
        </ul>
        <a
          class="plan-cta plan-cta-orange"
          href="https://wa.me/59178960077?text=Hola%2C%20quiero%20contratar%20el%20Plan%20Est%C3%A1ndar"
          target="_blank"
          rel="noopener noreferrer"
          id="cta-plan-estandar"
          data-plan="Estándar">Elegir Plan Estándar</a
        >
      </div>

      <!-- Profesional -->
      <div class="plan-card reveal" style="transition-delay: 240ms" id="plan-profesional">
        <div class="plan-head">
          <h3 class="plan-name plan-name-purple">Profesional</h3>
          <div class="plan-price-row">
            <span class="plan-price" data-monthly="Bs 499" data-annual="Bs 4.990">Bs 499</span>
            <span class="plan-period" data-monthly="/mes" data-annual="/año">/mes</span>
          </div>
          <p class="plan-price-equiv" aria-live="polite"></p>
          <span class="plan-annual-badge" aria-hidden="true">🎁 2 meses gratis</span>
        </div>
        <ul class="plan-features" aria-label="Beneficios plan Profesional">
          <li class="plan-feature">
            <svg class="check-svg check-purple" viewBox="0 0 20 20" fill="currentColor"
              ><path

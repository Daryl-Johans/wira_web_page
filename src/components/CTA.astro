---
// CTA.astro — usa exclusivamente clases globales de global.css
---

<div class="cta-wave" aria-hidden="true">
  <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
    <path d="M0,30 C360,60 1080,0 1440,30 L1440,0 L0,0 Z" fill="#0f1629"></path>
  </svg>
</div>

<section class="wira-cta" id="contacto" aria-labelledby="cta-heading">
  <div class="wira-container cta-inner reveal">
    <div class="cta-copy">
      <span class="cta-eyebrow">¿Listo para empezar?</span>
      <h2 id="cta-heading" class="cta-title">
        El sistema que tu negocio<br /><em>estaba esperando</em>
      </h2>
      <p class="cta-sub">
        Únete a los negocios que ya confían en Wira Systems. Accede directamente desde la Web o
        instala nuestra App.
      </p>
      <div class="cta-btns">
        <a
          id="cta-probar-ahora"
          class="cta-btn-white"
          href="https://wirasystems.web.app"
          target="_blank"
          rel="noopener noreferrer"
        >
          Probar ahora
        </a>
        <a
          id="cta-whatsapp"
          class="cta-btn-ghost-white"
          href="https://wa.me/59174000000?text=Hola%2C%20quiero%20más%20información%20sobre%20Wira%20Systems"
          target="_blank"
          rel="noopener noreferrer"
        >
          Contáctanos
        </a>
      </div>
    </div>
    <div class="cta-stats" aria-label="Estadísticas de Wira Systems">
      <div class="cta-stat">
        <span class="cta-stat-num">100%</span>
        <span class="cta-stat-label">Control en tiempo real</span>
      </div>
      <div class="cta-stat">
        <span class="cta-stat-num" data-count="3">3</span>
        <span class="cta-stat-label">Planes disponibles</span>
      </div>
      <div class="cta-stat">
        <span class="cta-stat-num">24/7</span>
        <span class="cta-stat-label">Soporte prioritario Pro</span>
      </div>
    </div>
  </div>
</section>

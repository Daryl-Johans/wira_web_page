{
  "name": "wira-web-page",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "description": "Sitio web de Wira Systems construido con Astro y Harness Engineering",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint \"src/**/*.{astro,ts,js,css}\" --fix",
    "lint:check": "eslint \"src/**/*.{astro,ts,js,css}\"",
    "format": "prettier --write \"src/**/*.{astro,ts,js,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{astro,ts,js,css,md}\"",
    "test": "astro check && npm run lint:check && npm run build",
    "verify": "powershell -ExecutionPolicy Bypass -File ./verify_harness.ps1"
  },
  "dependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.20.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.3.0",
    "prettier": "^3.4.0",
    "prettier-plugin-astro": "^0.14.0",
    "typescript": "^5.6.0"
  }
}
